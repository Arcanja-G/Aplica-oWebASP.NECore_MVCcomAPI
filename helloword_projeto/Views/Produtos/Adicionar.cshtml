@model Produto
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Adicionar Produto";
}
<h2>Adicionar Produtos</h2>

<form method="post">
   
    <div class="form-group">
        <label asp-for="Nome">Nome</label> 
        <input asp-for="Nome" class="form-control "  placeholder="Insira o nome" />
        <small class="form-text text-muted"><span asp-validation-for="Nome" class="text-danger"></span></small>
    </div>
    <div class="form-group">
        <label asp-for="Preco" class="mt-3">Preço</label>
        <input asp-for="Preco" class="form-control" placeholder="Insira o preço do produto" />
        <small class="form-text text-muted"><span asp-validation-for="Preco" class="text-danger"></span></small>
    </div>
    <div>
        <button type="submit" class="btn btn-primary mt-3">Adicionar</button>
        <a asp-controller="Produtos" asp-action="Index" class="btn btn-outline-secondary">Voltar aos produtos</a>
    </div>
</form>

@section Scripts{
        <partial name="_ValidationScriptsPartial" />
}


