@{
}
<partial name="_Notificacoes" />

<h1>Clientes</h1>


<table class="table table-striped table-hover">
    <thead>
        <a asp-controller="Clientes" asp-action="Adicionar">Adicionar Cliente</a>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Telefone</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var clt in Model)
        {
            <tr>
                <td>@clt.Id</td>
                <td> @clt.Nome</td>
                <td> @clt.Email</td>
                <td> @clt.Telefone</td>
                <td class="text-end">
                    <a asp-action="Editar" asp-route-id="@clt.Id" class="btn btn-primary">Editar</a>
                    <a asp-action="Apagar" asp-route-id="@clt.Id" class="btn btn-outline-danger">Apagar</a>

                </td>
            </tr>

        <!--<td>
            <a asp-action="Editar" asp-rout-id="@clt.Id" class="btn btn-primary">Editar</a>
            </td> -->
        }


    </tbody>
</table>
