
@model Cliente
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Apagar Cliente";
}

<h2>Apagar Cliente</h2>

<form method="post">
    <div class="form-group">
        <label asp-for="Nome">Nome</label>
        <input asp-for="Nome" class="form-control " readonly disable />
        <small class="form-text text-muted"><span asp-validation-for="Nome" class="text-danger"></span></small>
    </div>
    <div class="form-group">
        <label asp-for="Email" class="mt-3">Email</label>
        <input asp-for="Email" class="form-control" readonly disable />
        <small class="form-text text-muted"><span asp-validation-for="Email" class="text-danger"></span></small>

    </div>
    <div class="form-group">
        <label asp-for="Telefone" class="mt-3">Telefone</label>
        <input asp-for="Telefone" class="form-control" readonly disable />
        <small class="form-text text-muted"><span asp-validation-for="Telefone" class="text-danger"></span></small>

    </div>
    <div>
        <button type="submit" onclick="return confirm('Deseja mesmo apagar?')" class="btn btn-danger ">Apagar</button>
        <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-secondary">Voltar aos clientes</a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


