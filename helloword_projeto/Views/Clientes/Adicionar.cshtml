@model Cliente
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Adicionar Cliente";
}
<h2>Adicionar Cliente</h2>

<form method="post">
    <div class="form-group">
        <label asp-for="Nome">Nome</label>
        <input asp-for="Nome" class="form-control " placeholder="Insira o nome" />
        <small class="form-text text-muted"><span asp-validation-for="Nome" class="text-danger"></span></small>
    </div>
    <div class="form-group">
        <label asp-for="Email" class="mt-3">Email</label>
        <input asp-for="Email" class="form-control" placeholder="Insira o Email" />
        <small class="form-text text-muted"><span asp-validation-for="Email" class="text-danger"></span></small>

    </div>
    <div class="form-group">
        <label asp-for="Telefone" class="mt-3">Telefone</label>
        <input asp-for="Telefone" class="form-control" placeholder="Insira o Telefone" />
        <small class="form-text text-muted"><span asp-validation-for="Telefone" class="text-danger"></span></small>

    </div>
    <div>
        <button type="submit" class="btn btn-primary mt-3">Adicionar</button>
        <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-secondary">Voltar a lista de clientes</a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


